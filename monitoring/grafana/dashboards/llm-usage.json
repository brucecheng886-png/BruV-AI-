{
  "id": null,
  "uid": "llm-usage",
  "title": "AI 知識庫 — LLM 使用量與成本",
  "tags": ["ai-kb", "llm"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "LLM 呼叫總次數（依模型）",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (llm_calls_total)",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Token 使用總量（依類型）",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "purple" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (llm_tokens_total)",
          "legendFormat": "{{ type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "估算總成本 (USD)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (llm_cost_usd_total)",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "呼叫速率 (calls/min)，依模型 + 呼叫類型",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model, call_type) (rate(llm_calls_total[5m])) * 60",
          "legendFormat": "{{ model }} / {{ call_type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Token 速率 (tokens/sec)，依模型 + 類型",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model, type) (rate(llm_tokens_total[5m]))",
          "legendFormat": "{{ model }} / {{ type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM 延遲 P50 / P95 / P99（依模型）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ model }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{ model }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (model, le) (rate(llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{ model }}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "成本累積速率 (USD/hour)，依模型",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(llm_cost_usd_total[5m])) * 3600",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "成功 vs 失敗呼叫（依模型）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model, success) (rate(llm_calls_total[5m])) * 60",
          "legendFormat": "{{ model }} / success={{ success }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Provider 呼叫分布",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider) (llm_calls_total)",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    }
  ]
}
