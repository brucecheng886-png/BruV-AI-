# ================================================================
# 地端 AI 知識庫 — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# 警告：.env 不得 commit 至 git
# ================================================================

# --- PostgreSQL ---
POSTGRES_USER=ai_kb_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=ai_kb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=chunks

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_password
MINIO_BUCKET=ai-kb-files

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=bge-m3

# --- Playwright Service ---
PLAYWRIGHT_SERVICE_URL=http://playwright-service:3002

# --- SearXNG ---
SEARXNG_URL=http://searxng:8080

# --- 加密金鑰（插件 auth_header 加密用）---
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLUGIN_ENCRYPT_KEY=your_fernet_key_here

# --- JWT ---
JWT_SECRET_KEY=changeme_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- 應用程式 ---
APP_ENV=development
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Grafana ---
# Grafana 管理員密碼（登入 http://localhost:3001，帳號 admin）
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# --- 備份設定 ---
# 本機備份儲存根目錄（Windows 路徑）
BACKUP_ROOT=C:\ai_kb_backups
# 備份保留天數
BACKUP_RETENTION_DAYS=7

# --- Neo4j Auth ---
# 格式：username/password（對應 NEO4J_USER / NEO4J_PASSWORD 上方設定）
NEO4J_AUTH=neo4j/changeme_neo4j_password

# --- 監控 ---
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
