{
  "name": "bruv-ai-kb",
  "version": "1.1.6",
  "description": "BruV AI 知識庫 — 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.bruvai.app",
    "productName": "BruV AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "loading.html",
      "loading-preload.js",
      "setup-wizard.html",
      "setup-preload.js",
      "preload.js",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../docker-compose.release.yml",
        "to": "docker-compose.yml"
      },
      {
        "from": "../scripts/init_db.sql",
        "to": "init_db.sql"
      },
      {
        "from": "../.env.example",
        "to": ".env.example"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "BruV.AI.Setup.${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "BruV AI",
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "brucecheng886-png",
      "repo": "BruV-AI-",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "svg2ico": "^1.0.35"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
