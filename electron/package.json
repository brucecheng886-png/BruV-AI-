{
  "name": "bruv-ai-kb",
  "version": "1.0.0",
  "description": "BruV AI 知識庫 — 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.bruvai.app",
    "productName": "BruV AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "loading.html",
      "loading-preload.js",
      "setup-wizard.html",
      "setup-preload.js",
      "preload.js",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../docker-compose.yml",
        "to": "docker-compose.yml"
      },
      {
        "from": "../.env.example",
        "to": ".env.example"
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/node_modules/**"
        ]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!dist/**",
          "!**/*.log",
          "!build_log.txt",
          "!build_output.txt",
          "!docker_build.txt"
        ]
      },
      {
        "from": "../playwright-service",
        "to": "playwright-service",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/node_modules/**"
        ]
      },
      {
        "from": "../scripts",
        "to": "scripts",
        "filter": [
          "init_db.sql"
        ]
      },
      {
        "from": "../nginx",
        "to": "nginx"
      },
      {
        "from": "../monitoring",
        "to": "monitoring"
      },
      {
        "from": "../searxng",
        "to": "searxng"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BruV AI"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "brucecheng886-png",
        "repo": "BruV-AI-",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "svg2ico": "^1.0.35"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
